# Public app URLs used by client-side pages and emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Required for NextAuth/session signing.
NEXTAUTH_SECRET=change-me

# Optional server rate labels.
NEXT_PUBLIC_EXP_RATE=Mid-High
NEXT_PUBLIC_PENYA_RATE=High
NEXT_PUBLIC_DROP_RATE=Mid

# Database settings are optional for build-only/demo deploys.
# Leave these empty when you only want GitHub/Vercel to build the site without SQL Server.
DB_USER=
DB_PASS=
DB_SERVER=
DB_NAME=
DB_PORT=
DB_INSTANCE=

# Optional integrations.
GMAIL_USER=
GMAIL_APP_PASSWORD=
PAYMONGO_SECRET_KEY=
GTOP_PINGBACK_KEY=
SALT_PASSWORD=
